<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Your Password</title>
    <style type="text/css">
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        color: #222222;
        background: linear-gradient(135deg, #a800ff, #ff00c8);
      }
      .email-wrapper {
        max-width: 700px;
        margin: 0 auto;
        background-color: #fff;
        padding: 20px;
      }
      .email-header {
        background-color: #1e1e1e;
        padding: 30px;
        color: #f086d9;
        text-align: center;
      }
      .email-body {
        padding: 30px;
        background-color: #f4f3f3;
      }
      .email-footer {
        background-color: #1e1e1e;
        padding: 14px;
        color: #d55fbb;
        text-align: center;
      }
      .btn {
        display: inline-block;
        padding: 14px 32px;
        background: linear-gradient(135deg, #a800ff, #ff00c8);
        color: #fff !important;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 16px;
        margin: 20px 0;
      }
      img {
        padding: 24px;
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <div class="email-header">
        <img
          src="cid:logo"
          height="120"
          width="120"
          alt="D' Plush Choice Logo"
          style="
            display: block;
            margin: 0 auto;
            border-radius: 50%;
            box-shadow: 0 4px 16px rgba(168, 0, 255, 0.15);
            background: #fff;
          "
        />
        <h1 style="color: #a800ff; margin-top: 10px">Reset Your Password</h1>
      </div>
      <div class="email-body">
        <p style="font-size: 18px; color: #a800ff; font-weight: 600">
          Hello <%= name %>,
        </p>
        <p style="color: #222; font-size: 16px">
          We received a request to reset the password for your
          <b>D' Plush Choice</b> account. Click the button below to set a new
          password. This link will expire in <b>15 minutes</b>.
        </p>
        <div style="text-align: center">
          <a href="<%= resetUrl %>" class="btn">Reset My Password</a>
        </div>
        <p style="color: #888; font-size: 14px; margin-top: 20px">
          If you did not request a password reset, you can safely ignore this
          email. Your password will not change.
        </p>
        <p style="color: #888; font-size: 13px">
          If the button above doesn't work, paste this link into your
          browser:<br />
          <a
            href="<%= resetUrl %>"
            style="color: #a800ff; word-break: break-all"
            ><%= resetUrl %></a
          >
        </p>
      </div>
      <div class="email-footer">
        <p>&copy;2025 D' Plush Choice. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
